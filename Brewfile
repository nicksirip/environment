# Brewfile
# Run `brew bundle` to install all packages listed here.
# Run `brew bundle check` to verify all packages are installed.
# Run `brew bundle cleanup` to remove packages not listed here.

# Core shell
brew "bash"               # Bash >= 4 (macOS ships with 3.2)
brew "bash-completion@2"  # Tab completion framework for bash >= 4.1

# Terminal multiplexer
brew "tmux"

# Fuzzy finder
brew "fzf"

# Shell history
brew "atuin"
brew "bash-preexec"       # Required hook for atuin in bash

# SSH key management
brew "keychain"

# Shell prompt
brew "starship"

# Container management
brew "podman"
